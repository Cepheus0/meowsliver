DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meowsliver

# AI Provider: "codex_cli" (default) | "codex" (OpenAI API key) | "lmstudio" (local)
AI_PROVIDER=codex_cli

# ── Option A: Codex CLI (default) ───────────────────────────────────────────
# No API key needed. Uses Codex CLI subprocess with your ChatGPT/Codex subscription.
# Setup: npm install -g @openai/codex && codex login
# CODEX_CLI_TIMEOUT_MS=120000
# CODEX_CLI_WORKSPACE=/tmp

# ── Option B: OpenAI API key ─────────────────────────────────────────────────
# AI_PROVIDER=codex
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=30000

# ── Option C: LM Studio (local) ──────────────────────────────────────────────
# AI_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=
# LM_STUDIO_TIMEOUT_MS=45000
