{
  "name": "meowsliver",
  "version": "0.1.0",
  "private": true,
  "description": "Thai personal finance dashboard for importing and analyzing Meowjot-style transaction data with Next.js, Zustand, and Recharts.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pw": "bash scripts/playwright-fallback.sh",
    "test": "bun run test:unit && bun run test:smoke",
    "test:report": "bash scripts/run-node-tool.sh ./node_modules/tsx/dist/cli.mjs scripts/generate-test-report.ts",
    "test:smoke": "bun run test:smoke:api && bun run test:smoke:browser",
    "test:smoke:api": "bash scripts/run-node-tool.sh ./node_modules/tsx/dist/cli.mjs scripts/run-smoke-tests.ts",
    "test:smoke:browser": "bash scripts/run-node-tool.sh ./node_modules/tsx/dist/cli.mjs scripts/run-browser-smoke-tests.ts",
    "test:unit": "bash scripts/run-node-tool.sh ./node_modules/vitest/vitest.mjs run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bash scripts/run-node-tool.sh ./node_modules/tsx/dist/cli.mjs src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.0.1",
    "next": "^16.1.3",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0",
    "playwright-core": "^1.56.1",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
